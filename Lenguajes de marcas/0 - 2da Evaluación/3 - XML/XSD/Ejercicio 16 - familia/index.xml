<?xml version="1.0" encoding="UTF-8" ?>
<shiporder xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="familias.xsd"
           orderid="123">
    <orderperson>John Doe</orderperson>
    <shipto>
        <name>Receiver Name</name>
        <address>123 Street Name</address>
        <city>City</city>
        <country>Country</country>
    </shipto>
    <item>
        <title>Some Product</title>
        <note>Optional note</note>
        <quantity>2</quantity>
        <price>10.99</price>
    </item>
    <!-- You can have multiple <item> elements -->
    <item>
        <title>Another Product</title>
        <quantity>1</quantity>
        <price>20.50</price>
    </item>
</shiporder>
